{
  "name": "desktop-pet-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-assets": "node scripts/prepare-assets.mjs",
    "predev": "npm run prepare-assets",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "build:refresh-assets": "npm run prepare-assets && npm run build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "lucide-react": "^1.14.0",
    "vite": "^7.3.3",
    "typescript": "^5.9.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
